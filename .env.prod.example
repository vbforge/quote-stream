# ─────────────────────────────────────────────────────────────
# .env.prod.example — PRODUCTION SERVER
# On your server: copy to .env, fill in real values
# docker-compose -f docker-compose.prod.yml up -d
# ─────────────────────────────────────────────────────────────

# Your DockerHub username (so compose pulls the right image)
DOCKERHUB_USERNAME=your_dockerhub_username

# Strong random DB credentials for production
DB_USER=quotestream
DB_PASSWORD=replace_with_something_long_and_random
