# .env.prod.example
# Copy to .env on your server and fill in real values
# NEVER commit this file with real values

# Your DockerHub username (so compose can pull the right image)
DOCKERHUB_USERNAME=your_dockerhub_username

# Database credentials — use a strong random password in production
DB_USER=quotestream
DB_PASSWORD=change_me_to_something_strong_and_random
